# ─── Anthropic ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── ElevenLabs ──────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=...
# Fallback voice ID used if voice cloning fails
ELEVENLABS_FALLBACK_VOICE_ID=...

# ─── Cloudflare AI Gateway ───────────────────────────────────────────────────
# Format: https://gateway.ai.cloudflare.com/v1/{account_id}/{gateway_name}/anthropic
CF_AI_GATEWAY_URL=https://gateway.ai.cloudflare.com/v1/.../ironmind/anthropic

# ─── Cloudflare (set via wrangler secret for production) ─────────────────────
# These are handled by wrangler.toml bindings in production.
# Only needed locally if running wrangler dev with remote bindings.
CF_ACCOUNT_ID=...
CF_API_TOKEN=...

# ─── Frontend ────────────────────────────────────────────────────────────────
# Worker base URL — used by frontend to reach the Worker API
VITE_WORKER_URL=http://localhost:8787
